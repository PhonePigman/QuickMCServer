<UserControl x:Class="QuickMCServer.ServerListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0段目：ヘッダー -->
            <RowDefinition Height="*"/>
            <!-- 1段目：サーバーリスト -->
            <RowDefinition Height="Auto"/>
            <!-- 2段目：操作ボタンエリア -->
        </Grid.RowDefinitions>

        <!-- 【0段目】 ヘッダー部分 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <Button Content="← 戻る" Width="80" Height="30" Click="BackButton_Click"/>
            <TextBlock Text="サーバー一覧" FontSize="24" FontWeight="Bold" Margin="20,0,0,0"/>
        </StackPanel>

        <!-- 【1段目】 サーバーのリスト -->
        <ListView x:Name="ServerList" Grid.Row="1" Margin="10" FontSize="14">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="サーバー名" Width="200" DisplayMemberBinding="{Binding ServerName}"/>
                    <GridViewColumn Header="バージョン" Width="120" DisplayMemberBinding="{Binding Version}"/>
                    <GridViewColumn Header="メモリ" Width="100" DisplayMemberBinding="{Binding Ram}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- 【2段目】 操作ボタンエリア（横並びにするためにStackPanelで囲みます） -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20">

            <Button Content="選択したサーバーを管理" FontSize="20" FontWeight="Bold" 
                    Padding="10" Background="#2196F3" Foreground="White"
                    Click="ManageServerButton_Click"/>

            <!-- ★★★ ここに削除ボタンを追加 ★★★ -->
            <Button Content="選択したサーバーを削除" FontSize="20" FontWeight="Bold" 
                    Margin="30,0,0,0" Padding="10" Background="OrangeRed" Foreground="White"
                    Click="DeleteServerButton_Click"/>

        </StackPanel>
    </Grid>
</UserControl>