<UserControl x:Class="QuickMCServer.CreateServerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <Button Content="← 戻る" Width="80" Height="30" Click="BackButton_Click"/>
            <TextBlock Text="サーバーの新規作成" FontSize="24" FontWeight="Bold" Margin="20,0,0,0"/>
        </StackPanel>

        <!-- 設定項目 -->
        <ScrollViewer Grid.Row="1" Margin="20,10,20,10">
            <StackPanel>

                <TextBlock Text="サーバーの名前 (フォルダ名になります):" Margin="0,10,0,5" FontWeight="Bold"/>
                <TextBox x:Name="ServerNameBox" Text="MyNewServer" Height="25" FontSize="14"/>

                <TextBlock Text="サーバーの種類:" Margin="0,15,0,5" FontWeight="Bold"/>
                <ComboBox x:Name="TypeBox" Height="25" FontSize="14" SelectionChanged="TypeBox_SelectionChanged">
                    <ComboBoxItem Content="Vanilla (公式)"/>
                    <ComboBoxItem Content="Paper (プラグイン・軽量)"/>
                    <ComboBoxItem Content="Spigot (プラグイン)"/>
                </ComboBox>

                <TextBlock Text="Minecraft バージョン:" Margin="0,15,0,5" FontWeight="Bold"/>
                <ComboBox x:Name="VersionBox" Height="25" FontSize="14"/>

                <TextBlock Text="割り当てメモリ (例: 2048M, 2G, 3000):" Margin="0,15,0,5" FontWeight="Bold"/>
                <TextBox x:Name="RamBox" Text="2048M" Height="25" FontSize="14" VerticalContentAlignment="Center"/>

                <TextBlock Text="最大人数:" Margin="0,15,0,5" FontWeight="Bold"/>
                <TextBox x:Name="MaxPlayersBox" Text="20" Height="25" FontSize="14"/>

                <!-- ★★★ ここに追加：シード値入力欄 ★★★ -->
                <TextBlock Text="シード値 (空欄でランダム):" Margin="0,15,0,5" FontWeight="Bold"/>
                <TextBox x:Name="SeedBox" Text="" Height="25" FontSize="14"/>

                <TextBlock Text="ゲームモード:" Margin="0,15,0,5" FontWeight="Bold"/>
                <ComboBox x:Name="GameModeBox" Height="25" FontSize="14">
                    <ComboBoxItem Content="survival" IsSelected="True"/>
                    <ComboBoxItem Content="creative"/>
                    <ComboBoxItem Content="adventure"/>
                    <ComboBoxItem Content="spectator"/>
                </ComboBox>
            </StackPanel>
        </ScrollViewer>

        <!-- 作成ボタン -->
        <Button x:Name="CreateButton" Grid.Row="2" Content="この設定でサーバーを作成" FontSize="20" FontWeight="Bold" 
                Margin="20" Padding="10" Background="#4CAF50" Foreground="White"
                Click="CreateServerButton_Click"/>

        <!-- ステータスとプログレスバー -->
        <StackPanel x:Name="ProgressPanel" Grid.Row="3" Visibility="Collapsed" Margin="20,0,20,20">
            <TextBlock x:Name="StatusText" Text="ダウンロードを準備中..." FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <ProgressBar IsIndeterminate="True" Height="20"/>
        </StackPanel>
    </Grid>
</UserControl>